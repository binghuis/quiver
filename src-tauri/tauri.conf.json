{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quiver",
  "version": "0.1.1",
  "identifier": "com.songbinghui.quiver",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Quiver",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "publisher": "宋秉徽",
    "copyright": "Copyright © 2026 宋秉徽",
    "category": "DeveloperTool",
    "shortDescription": "跨 Claude / Codex / Gemini 的 skill 分发台",
    "longDescription": "Quiver 是一个桌面 App，集中管理 Claude / Codex / Gemini 三个 agent 生态里的 skill（SKILL.md 形式的提示包）。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
